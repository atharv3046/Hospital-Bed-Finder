{
  "cli": { "version": ">= 10.0.0", "appVersionSource": "remote" },
  "build": {
    "preview": {
      "android": { "buildType": "apk" },
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EX_UPDATES_NATIVE_DEBUG": "1"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "distribution": "store",
      "channel": "production"
    }
  }
}
